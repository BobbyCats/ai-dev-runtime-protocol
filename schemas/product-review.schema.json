{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bobbycats.github.io/ai-dev-runtime-protocol/schemas/product-review.schema.json",
  "title": "ProductReview",
  "type": "object",
  "required": [
    "schema_version",
    "review_id",
    "generated_at",
    "title",
    "brief_id",
    "current_goal",
    "core_user",
    "core_problem",
    "primary_scenario",
    "minimum_valuable_slice",
    "scope_decision",
    "scope_reason",
    "recommended_next_step"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "review_id": { "type": "string" },
    "generated_at": { "type": "string" },
    "title": { "type": "string" },
    "brief_id": { "type": "string" },
    "current_goal": { "type": "string" },
    "core_user": { "type": "string" },
    "core_problem": { "type": "string" },
    "primary_scenario": { "type": "string" },
    "minimum_valuable_slice": { "type": "string" },
    "non_goals": {
      "type": "array",
      "items": { "type": "string" }
    },
    "scope_decision": {
      "type": "string",
      "enum": ["expand", "hold", "shrink"]
    },
    "scope_decision_label": { "type": "string" },
    "scope_reason": { "type": "string" },
    "recommended_scope_decision": { "type": "string" },
    "recommended_scope_reason": { "type": "string" },
    "success_signals": {
      "type": "array",
      "items": { "type": "string" }
    },
    "expansion_triggers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recommended_next_step": { "type": "string" }
  }
}
