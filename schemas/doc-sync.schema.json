{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bobbycats.github.io/ai-dev-runtime-protocol/schemas/doc-sync.schema.json",
  "title": "DocumentationSyncPack",
  "type": "object",
  "required": [
    "schema_version",
    "sync_id",
    "generated_at",
    "title",
    "summary",
    "changed_files",
    "readme_strategy",
    "impacted_docs",
    "sync_order",
    "definition_of_done"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "sync_id": { "type": "string" },
    "generated_at": { "type": "string" },
    "title": { "type": "string" },
    "summary": { "type": "string" },
    "changed_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "change_notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "categories": {
      "type": "array",
      "items": { "type": "string" }
    },
    "readme_strategy": {
      "type": "string",
      "enum": ["targeted-update", "section-rewrite", "full-rewrite"]
    },
    "readme_sections": {
      "type": "array",
      "items": { "type": "string" }
    },
    "impacted_docs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "action", "reason"],
        "properties": {
          "path": { "type": "string" },
          "action": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "sync_order": {
      "type": "array",
      "items": { "type": "string" }
    },
    "definition_of_done": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
